# Database Connection URL (PostgreSQL)
# Format: postgresql://username:password@host:port/database_name
# Note: If database password contains special characters (like @, %, etc.), they must be URL-encoded.
DATABASE_URL=postgresql://postgres:password@localhost:5432/student_performance_db

# Allowed CORS Origins (Comma-separated list of URLs)
# Used to secure backend endpoints in production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# OpenAI API Key (For chatbot features)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
